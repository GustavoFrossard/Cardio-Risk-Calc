@startuml
title Diagrama de Classes do Backend

class PatientData <<Pydantic BaseModel>> {
  +Optional<String> name
  +Optional<Integer> age
  +Boolean obesity
  +Boolean known_hf
  +Boolean known_valvular_disease
  +Boolean known_cad
  +Boolean uses_aas
  +String aas_prevention
  +Boolean uses_clopidogrel
  +Boolean uses_ticagrelor
  +Boolean uses_prasugrel
  +Boolean uses_warfarin
  +String warfarin_indication
  +Optional<Integer> warfarin_chadsvasc
  +Boolean warfarin_stroke_3m
  +String warfarin_vte_timing
  +String warfarin_thrombophilia
  +Boolean warfarin_active_neoplasia
  +List<String> functional_activities
  +Float mets
  +String surgery_type
  +String surgery_risk
  +Boolean is_vascular
  +Boolean cv_acute_coronary
  +Boolean cv_unstable_aortic
  +Boolean cv_acute_pulmonary_edema
  +Boolean cv_cardiogenic_shock
  +Boolean cv_hf_nyha_3_4
  +Boolean cv_angina_ccs_3_4
  +Boolean cv_severe_arrhythmia
  +Boolean cv_uncontrolled_hypertension
  +Boolean cv_af_high_rate
  +Boolean cv_pulmonary_hypertension
  +Boolean cv_severe_valvular
  +Boolean rcri_high_risk_surgery
  +Boolean rcri_ischemic_heart
  +Boolean rcri_heart_failure
  +Boolean rcri_cerebrovascular
  +Boolean rcri_insulin_diabetes
  +Boolean rcri_creatinine_above_2
  +String vsg_age_range
  +Boolean vsg_cad
  +Boolean vsg_chf
  +Boolean vsg_copd
  +Boolean vsg_creatinine_over_1_8
  +Boolean vsg_smoking
  +Boolean vsg_insulin_diabetes
  +Boolean vsg_chronic_beta_blocker
  +Boolean vsg_prior_revasc
}

enum SurgeryRisk {
  LOW
  INTERMEDIATE
  HIGH
}

enum RiskClass {
  LOW
  INTERMEDIATE
  HIGH
}

enum RecommendationType {
  GREEN
  AMBER
  RED
}

class FastAPIApp <<main.py>> {
  +root(): dict
  +calculate(patient: PatientData): dict
  +health(): dict
}

class Calculator <<core/calculator.py>> {
  +calculate_risk(data: dict): dict
  +score_rcri(data: dict): tuple[int, list]
  +score_vsg(data: dict): tuple[int, list]
  +check_active_conditions(data: dict): list[str]
  +classify_risk(pct: float): tuple[str, str]
  +build_medication_advice(data: dict): list[dict]
  +build_exam_recommendations(data, risk_class, score, has_active): list[str]
  +build_recommendations(risk_class, score, mets, ...): list[dict]
  +build_risk_factors(data, criteria_met, mets): list[str]
  -_get_rcri_risk(score: int): tuple[str, float]
  -_get_vsg_risk(score: int): tuple[str, float]
  -_determine_warfarin_bridging(data: dict): dict
}

FastAPIApp --> PatientData
FastAPIApp --> Calculator
Calculator --> SurgeryRisk
Calculator --> RiskClass
Calculator --> RecommendationType
@enduml
