@startuml
title Diagrama de Classes do Backend

class DadosPaciente <<Pydantic BaseModel>> {
  +Optional<String> nome
  +Optional<Integer> idade
  +Boolean obesidade
  +Boolean insuficiencia_cardiaca
  +Boolean doenca_valvar
  +Boolean doenca_coronariana
  +Boolean usa_aas
  +String prev_aas
  +Boolean usa_clopidogrel
  +Boolean usa_ticagrelor
  +Boolean usa_prasugrel
  +Boolean usa_varfarina
  +String indicacao_varfarina
  +Optional<Integer> chadsvasc_varfarina
  +Boolean avc3m_varfarina
  +String tev_tempo_varfarina
  +String trombofilia_varfarina
  +Boolean neoplasia_ativa_varfarina
  +List<String> atividades_funcionais
  +Float mets
  +String tipo_cirurgia
  +String risco_cirurgia
  +Boolean cirurgia_vascular
  +Boolean sca_ativa
  +Boolean aorta_instavel
  +Boolean edema_pulmonar_agudo
  +Boolean choque_cardiogenico
  +Boolean ic_nyha_3_4
  +Boolean angina_ccs_3_4
  +Boolean arritmia_grave
  +Boolean hipertensao_nao_controlada
  +Boolean fa_alta_resposta
  +Boolean hipertensao_pulmonar
  +Boolean valvopatia_importante
  +Boolean rcri_cirurgia_alto_risco
  +Boolean rcri_doenca_coronaria
  +Boolean rcri_ic
  +Boolean rcri_cerebrovascular
  +Boolean rcri_diabetes_insulina
  +Boolean rcri_creatinina_maior_2
  +String vsg_faixa_idade
  +Boolean vsg_doenca_coronaria
  +Boolean vsg_ic
  +Boolean vsg_dpo
  +Boolean vsg_creatinina_maior_1_8
  +Boolean vsg_tabagismo
  +Boolean vsg_diabetes_insulina
  +Boolean vsg_betabloqueador
  +Boolean vsg_revasc_previa
}

enum RiscoCirurgia {
  BAIXO
  INTERMEDIARIO
  ALTO
}

enum ClasseRisco {
  BAIXA
  INTERMEDIARIA
  ALTA
}

enum TipoRecomendacao {
  VERDE
  AMARELO
  VERMELHO
}

class AplicacaoFastAPI <<main.py>> {
  +raiz(): dict
  +calcular(paciente: PatientData): dict
  +saude(): dict
}

class Calculadora <<core/calculator.py>> {
  +calcular_risco(dados: dict): dict
  +pontuar_rcri(dados: dict): tuple[int, list]
  +pontuar_vsg(dados: dict): tuple[int, list]
  +verificar_condicoes_ativas(dados: dict): list[str]
  +classificar_risco(pct: float): tuple[str, str]
  +montar_orientacoes_medicacao(dados: dict): list[dict]
  +montar_recomendacoes_exames(dados, classe_risco, score, tem_ativa): list[str]
  +montar_recomendacoes(classe_risco, score, mets, ...): list[dict]
  +montar_fatores_risco(dados, criterios, mets): list[str]
  -_obter_risco_rcri(score: int): tuple[str, float]
  -_obter_risco_vsg(score: int): tuple[str, float]
  -_determinar_ponte_varfarina(dados: dict): dict
}

AplicacaoFastAPI --> DadosPaciente
AplicacaoFastAPI --> Calculadora
Calculadora --> RiscoCirurgia
Calculadora --> ClasseRisco
Calculadora --> TipoRecomendacao
@enduml
