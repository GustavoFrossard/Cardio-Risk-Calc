@startuml
title Arquitetura Frontend / Backend

package Frontend {
  [App.jsx] <<React>>
  [AppHeader.jsx] <<React>>
  [BottomBar.jsx] <<React>>
  [StepPatientData.jsx] <<React>>
  [StepSurgery.jsx] <<React>>
  [StepRCRI.jsx] <<React>>
  [StepResult.jsx] <<React>>
  [hooks/useWizard.js] <<Hook>>
  [services/api.js] <<Serviço>>
  [services/report.js] <<Serviço>>
  [types/index.js] <<Constantes>>
  [components/ui] <<UI Components>>
}

package Backend {
  [backend/main.py] <<FastAPI>>
  [backend/core/calculator.py] <<Calculadora>>
}

[App.jsx] --> [AppHeader.jsx]
[App.jsx] --> [BottomBar.jsx]
[App.jsx] --> [hooks/useWizard.js]
[App.jsx] --> [StepPatientData.jsx]
[App.jsx] --> [StepSurgery.jsx]
[App.jsx] --> [StepRCRI.jsx]
[App.jsx] --> [StepResult.jsx]
[hooks/useWizard.js] --> [services/api.js]
[hooks/useWizard.js] --> [types/index.js]
[StepPatientData.jsx] --> [components/ui]
[StepPatientData.jsx] --> [types/index.js]
[StepSurgery.jsx] --> [components/ui]
[StepSurgery.jsx] --> [types/index.js]
[StepRCRI.jsx] --> [components/ui]
[StepResult.jsx] --> [services/report.js]
[AppHeader.jsx] --> [types/index.js]
[services/api.js] --> [backend/main.py]
[backend/main.py] --> [backend/core/calculator.py]

@enduml
