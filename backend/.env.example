# =============================================================
# CardioRisk Backend — Configuração do Assistente de IA
# =============================================================
# Por padrão tudo roda LOCAL via PyTorch. Nenhuma configuração
# é obrigatória — o modelo é baixado automaticamente na 1ª execução.

# ----- Modelo de geração local (padrão, sem API key) -----
# Baixado automaticamente do Hugging Face (~1.5 GB)
# GENERATION_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Modelos alternativos:
# GENERATION_MODEL=Qwen/Qwen2.5-0.5B-Instruct   <- menor, ~1 GB, mais rápido
# GENERATION_MODEL=Qwen/Qwen2.5-3B-Instruct     <- melhor qualidade, ~6 GB

# ----- Modelo de embeddings (busca semântica) -----
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ----- Warmup e logs do backend local -----
# Pré-carrega modelos no startup para evitar delay na 1ª mensagem do chat.
# CARDIORISK_CHAT_PRELOAD=true

# Exibe logs de "model loaded" no console. Deixe false para menos ruído.
# CARDIORISK_VERBOSE_MODEL_LOAD=false

# Suprime warnings verbosos de libs de IA (Windows/CUDA/HF).
# CARDIORISK_SUPPRESS_MODEL_WARNINGS=true

# Em Windows, deixe false para evitar erros de device/meta com offload automático.
# CARDIORISK_USE_DEVICE_MAP_AUTO=false

# Fallback se o modelo principal não carregar na GPU/RAM disponível.
# CARDIORISK_FALLBACK_GENERATION_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Caminho opcional para adaptador LoRA treinado localmente.
# CARDIORISK_LORA_ADAPTER_PATH=outputs/cardiorisk-lora

# Opcional: ativa modo determinístico de cálculo no chat (regras), desative para confiar só no modelo.
# CARDIORISK_ENABLE_DETERMINISTIC_CALC=false

# Token opcional do Hugging Face para reduzir warnings e melhorar limites/download.
# HF_TOKEN=hf_xxx

# ----- Fallback opcional: OpenAI API -----
# Se definido, usa OpenAI em vez do modelo local.
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
