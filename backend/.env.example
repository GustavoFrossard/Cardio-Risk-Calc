# =============================================================
# CardioRisk Backend — Configuração do Assistente de IA
# =============================================================
# Por padrão tudo roda LOCAL via PyTorch. Nenhuma configuração
# é obrigatória — o modelo é baixado automaticamente na 1ª execução.

# ----- Modelo de geração local (padrão, sem API key) -----
# Baixado automaticamente do Hugging Face (~1.5 GB)
# GENERATION_MODEL=Qwen/Qwen2.5-1.5B-Instruct

# Modelos alternativos:
# GENERATION_MODEL=Qwen/Qwen2.5-0.5B-Instruct   <- menor, ~1 GB, mais rápido
# GENERATION_MODEL=Qwen/Qwen2.5-3B-Instruct     <- melhor qualidade, ~6 GB

# ----- Modelo de embeddings (busca semântica) -----
# EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ----- Fallback opcional: OpenAI API -----
# Se definido, usa OpenAI em vez do modelo local.
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o-mini
